{
  "cli": {
    "version": ">= 13.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "env": { "EXPO_PUBLIC_GOOGLE_MAPS_KEY": "AIzaSyC9edB8_0YFshQ5-yXFZMra34CYylor5Ck" },
      "ios":     { "simulator": true, "resourceClass": "m-medium" },
      "android": { "buildType": "apk", "gradleCommand": ":app:assembleDebug" }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "env": { "EXPO_PUBLIC_GOOGLE_MAPS_KEY": "AIzaSyC9edB8_0YFshQ5-yXFZMra34CYylor5Ck" },
      "ios":     { "resourceClass": "m-medium" },
      "android": { "buildType": "apk" }
    },
    "production": {
      "distribution": "store",
      "channel": "production",
      "autoIncrement": true,
      "env": { "EXPO_PUBLIC_GOOGLE_MAPS_KEY": "AIzaSyC9edB8_0YFshQ5-yXFZMra34CYylor5Ck" },
      "ios":     { "resourceClass": "m-medium" },
      "android": { "buildType": "app-bundle" }
    }
  },
  "submit": {
    "production": {
      "ios":     { "appleId": "ops@kyra.app", "ascAppId": "REPLACE_WITH_ASC_APP_ID", "appleTeamId": "REPLACE_WITH_APPLE_TEAM_ID" },
      "android": { "serviceAccountKeyPath": "../google-play-service-account.json", "track": "internal" }
    }
  }
}
